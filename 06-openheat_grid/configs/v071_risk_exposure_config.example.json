{
  "crs_projected": "EPSG:3414",
  "grid_csv": "data/grid/toa_payoh_grid_v07_features_beta_final.csv",
  "grid_geojson": "data/grid/toa_payoh_grid_v07_features.geojson",
  "forecast_dir": "outputs/v07_beta_final_forecast_live",
  "out_dir": "outputs/v071_risk_exposure",
  "out_grid_csv": "data/grid/toa_payoh_grid_v07_features_beta_final_v071_risk.csv",
  "raw_paths": {
    "census_age_subzone_csv": "data/raw/demographics/singstat_subzone_age_2020.csv",
    "subzone_boundary_geojson": "data/raw/boundaries/ura_mp19_subzone_no_sea.geojson",
    "bus_stops_geojson": "data/raw/poi/lta_bus_stops.geojson",
    "mrt_exits_geojson": "data/raw/poi/lta_mrt_exits.geojson",
    "hawker_centres_geojson": "data/raw/poi/nea_hawker_centres.geojson",
    "sport_facilities_geojson": "data/raw/poi/sportsg_facilities.geojson",
    "eldercare_services_geojson": "data/raw/poi/moh_eldercare_services.geojson",
    "preschools_geojson": "data/raw/poi/ecda_preschools.geojson"
  },
  "demographic_weights": {
    "elderly_pct_65plus": 0.75,
    "children_pct_under5": 0.25
  },
  "node_types": {
    "bus_stop": {
      "path_key": "bus_stops_geojson",
      "score_group": "outdoor_exposure",
      "weight": 1.0,
      "decay_m": 150,
      "search_radius_m": 450,
      "name_columns": ["BUS_STOP_NUM", "BUS_ROOF_NUM"]
    },
    "mrt_exit": {
      "path_key": "mrt_exits_geojson",
      "score_group": "outdoor_exposure",
      "weight": 2.0,
      "decay_m": 250,
      "search_radius_m": 750,
      "name_columns": ["STATION_NA", "EXIT_CODE"]
    },
    "sport_facility": {
      "path_key": "sport_facilities_geojson",
      "score_group": "outdoor_exposure",
      "weight": 0.7,
      "decay_m": 200,
      "search_radius_m": 600,
      "name_columns": ["VENUE", "POSTAL_CODE"]
    },
    "hawker_centre": {
      "path_key": "hawker_centres_geojson",
      "score_group": "node_vulnerability",
      "weight": 0.8,
      "decay_m": 250,
      "search_radius_m": 750,
      "name_columns": ["NAME", "ADDRESSBUILDINGNAME"],
      "size_weight_column": "NUMBER_OF_COOKED_FOOD_STALLS",
      "size_weight_mode": "sqrt_relative_to_median"
    },
    "eldercare": {
      "path_key": "eldercare_services_geojson",
      "score_group": "node_vulnerability",
      "weight": 1.5,
      "decay_m": 250,
      "search_radius_m": 750,
      "name_columns": ["NAME", "Name", "CENTRE_NAME", "SERVICE_NAME", "HCI_NAME"]
    },
    "preschool": {
      "path_key": "preschools_geojson",
      "score_group": "node_vulnerability",
      "weight": 0.5,
      "decay_m": 150,
      "search_radius_m": 450,
      "name_columns": ["CENTRE_NAME", "NAME", "Name"]
    }
  },
  "risk_weights": {
    "risk_priority_score_v071": {
      "hazard_score": 0.60,
      "vulnerability_score_v071": 0.25,
      "outdoor_exposure_score_v071": 0.15
    },
    "risk_priority_score_v071_equity": {
      "hazard_score": 0.50,
      "vulnerability_score_v071": 0.35,
      "outdoor_exposure_score_v071": 0.15
    },
    "vulnerability_score_v071": {
      "demographic_vulnerability_score": 0.70,
      "node_vulnerability_score": 0.30
    }
  },
  "notes": {
    "model_scope": "v0.7.1 uses static open-data proxies. It estimates potential vulnerability/exposure, not real-time people counts or activity-space exposure.",
    "time_of_day_limit": "Outdoor exposure nodes are static and not time-of-day weighted in v0.7.1. Peak heat exposure around 13:00-16:00 may not match node activity peaks.",
    "maup_limit": "Subzone demographic vulnerability is an area-based residential proxy and may not represent where residents spend time during the day."
  }
}
