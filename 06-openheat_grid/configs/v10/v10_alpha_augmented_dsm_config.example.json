{
  "crs": "EPSG:3414",
  "wgs84_crs": "EPSG:4326",
  "resolution_m": 2,
  "aoi_buffer_m": 200,
  "base_grid_geojson": "data/grid/toa_payoh_grid_v07_features.geojson",
  "aoi_buffered_geojson": "data/features_3d/aoi_buffered_200m.geojson",
  "old_building_dsm": "data/rasters/v08/dsm_buildings_2m_toapayoh.tif",

  "sources": {
    "hdb3d": "data/features_3d/hdb3d_buildings_toapayoh.geojson",
    "ura": "data/features_3d/ura_buildings_toapayoh.geojson",
    "osm": "data/raw/buildings_v10/osm_buildings_toapayoh.geojson",
    "ura_land_use": "data/raw/ura_masterplan2019_land_use.geojson"
  },

  "overpass": {
    "endpoints": [
      "https://overpass-api.de/api/interpreter",
      "https://overpass.kumi.systems/api/interpreter",
      "https://overpass.openstreetmap.ru/api/interpreter"
    ],
    "timeout_seconds": 180,
    "user_agent": "OpenHeat-ToaPayoh-v10-alpha/1.0 (academic research; contact via project owner)",
    "include_relations": false,
    "building_query_filter": "[\"building\"]"
  },

  "dedup": {
    "source_priority": {
      "hdb3d": 1,
      "ura": 2,
      "osm": 3
    },
    "min_area_m2": {
      "hdb3d": 5,
      "ura": 5,
      "osm": 10
    },
    "duplicate_iou_threshold": 0.35,
    "duplicate_candidate_overlap_threshold": 0.60,
    "duplicate_existing_overlap_threshold": 0.30,
    "new_candidate_overlap_threshold": 0.20,
    "centroid_distance_threshold_m": 8,
    "area_ratio_min": 0.50,
    "area_ratio_max": 2.00,
    "conflict_large_area_m2": 1000
  },

  "height_imputation": {
    "levels_height_m": 3.0,
    "min_valid_height_m": 2.0,
    "max_valid_height_m": 180.0,
    "land_use_defaults_m": {
      "HDB": 30,
      "RESIDENTIAL": 15,
      "COMMERCIAL": 20,
      "BUSINESS PARK": 24,
      "HOTEL": 30,
      "EDUCATIONAL": 12,
      "CIVIC": 12,
      "COMMUNITY": 12,
      "HEALTH": 18,
      "HOSPITAL": 24,
      "INDUSTRIAL": 10,
      "UTILITY": 8,
      "TRANSPORT": 8,
      "RELIGIOUS": 10,
      "PLACE OF WORSHIP": 10,
      "SPORTS": 9,
      "PARK": 6,
      "OPEN SPACE": 6,
      "UNKNOWN_SMALL": 5,
      "UNKNOWN_NORMAL": 10,
      "UNKNOWN_LARGE": 12
    },
    "small_area_m2": 50,
    "large_area_m2": 1000
  },

  "outputs": {
    "osm_raw": "data/raw/buildings_v10/osm_buildings_toapayoh.geojson",
    "source_standardized_dir": "data/features_3d/v10/source_standardized",
    "all_candidates": "data/features_3d/v10/canonical_candidates/all_building_candidates_v10.geojson",
    "canonical_buildings": "data/features_3d/v10/canonical/canonical_buildings_v10.geojson",
    "canonical_conflicts": "data/features_3d/v10/canonical/canonical_buildings_v10_conflicts.geojson",
    "canonical_buildings_height": "data/features_3d/v10/height_imputed/canonical_buildings_v10_height.geojson",
    "height_qa_csv": "data/features_3d/v10/height_imputed/height_imputation_QA.csv",
    "augmented_dsm": "data/rasters/v10/dsm_buildings_2m_augmented.tif",
    "source_qa_report": "outputs/v10_dsm_audit/v10_source_standardization_QA.md",
    "dedup_qa_report": "outputs/v10_dsm_audit/v10_dedup_QA_report.md",
    "height_qa_report": "outputs/v10_dsm_audit/v10_height_imputation_QA.md",
    "raster_qa_report": "outputs/v10_dsm_audit/v10_rasterize_augmented_dsm_QA.md",
    "completeness_per_cell": "outputs/v10_dsm_audit/v10_building_completeness_per_cell.csv",
    "completeness_per_tile": "outputs/v10_dsm_audit/v10_building_completeness_per_tile.csv",
    "completeness_gain_report": "outputs/v10_dsm_audit/v10_completeness_gain_report.md",
    "completeness_map_geojson": "outputs/v10_dsm_audit/v10_building_completeness_map.geojson"
  },

  "optional_inputs": {
    "v09_tiles_buffered_geojson": "data/solweig/v09_tiles_overhead_aware/v09_solweig_tiles_overhead_aware_buffered.geojson"
  }
}
